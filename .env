# Токен вашего Telegram-бота от @BotFather
# Пример: 1234567890:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_TOKEN=8443172037:AAEnPlGlNwMXvphSZbcuD4VVCt71Ze7IR1I

# ID администраторов, которым доступна админ-панель
# Указывать через запятую, без пробелов или с пробелами (не критично)
# Пример: 123456789,987654321
ADMIN_IDS=8241903547, 7227313074

# Путь к SQLite базе данных (можно оставить по умолчанию)
# Пример: bot.sqlite3
DB_PATH=bot.sqlite3

# Антифлуд: минимальная задержка между действиями пользователя (в секундах)
# Пример: 0.7
RATE_LIMIT_SECONDS=0.7

# Режим оплаты:
# simulate = тестовый режим (кнопка "Я оплатил")
# crypto_pay = оплата через Crypto Pay API
PAYMENT_MODE=crypto_pay

# API-токен приложения Crypto Pay (Crypto Bot)
# Получить в @CryptoBot -> Crypto Pay -> My Apps -> API Token
CRYPTO_PAY_API_TOKEN=554156:AA2iJa5Lh3LIEizjDLFaKYG17K1y1LIv6bM

# Базовый URL API Crypto Pay (обычно менять не нужно)
CRYPTO_PAY_BASE_URL=https://pay.crypt.bot/api

# Опционально: file_id стикера, который бот отправит на /start
# Можно оставить пустым
WELCOME_STICKER_ID=

# Как часто бот проверяет задачи рассылки (в секундах)
# Пример: 15
SCHEDULER_TICK_SECONDS=15
